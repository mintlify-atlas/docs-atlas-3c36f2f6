    "@magicyan/core - format, validation, timers, date, math, convert, check, with, sleep",
    "@magicyan/discord - channels, members, roles, embeds, components, messages, commands, webhooks",
    "@magicyan/discord-events - initDiscordEvents, extendedRoleCreate, guildMemberConnect, userBanAdd, webhookMessageCreate",
    "@magicyan/discord-ui - menus, prompts",
    "@magicyan/canvas - CanvasBuilder and utility functions",
    "@magicyan/minecraft - mojang, server, skins API wrappers"
